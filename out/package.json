{
	"name": "alepsychluaautocompleter",
	"displayName": "ALE Psych Lua Autocompleter",
	"publisher": "AlejoGDOfficial",
	"version": "0.0.3",
	"repository": "https://github.com/ALE-Psych-Crew/ALE-Psych-Lua-Autocompleter",
	"engines": {
		"vscode": "^1.4.0"
	},
	"activationEvents": [
		"onLanguage:lua"
	],
	"main": "./extension.js",
	"extensionDependencies": [
		"sumneko.lua"
	],
	"contributes": {
		"commands": [
			{
				"command": "alepsychlua.enable",
				"title": "ALEPsych: Enable"
			},
			{
				"command": "alepsychlua.disable",
				"title": "ALEPsych: Disable"
			}
		]
	}
}